# ── Required ─────────────────────────────────────────────────────────────────
# Use a different PORT than video-manch-backend if both run on your machine (API often 3001).
PORT=3002
API_BASE_URL=http://localhost:3001
# Must match video-manch-backend LIVE_INGEST_SHARED_SECRET
LIVE_INGEST_SHARED_SECRET=change-me-to-match-backend

# ── Modes ───────────────────────────────────────────────────────────────────
# Browser WebSocket ingest (default true)
ENABLE_WS_INGEST=true
# Local RTMP + MediaMTX + HLS proxy (default false)
ENABLE_RTMP_SERVER=false

# ── Binaries ────────────────────────────────────────────────────────────────
FFMPEG_BIN=/usr/bin/ffmpeg
MEDIAMTX_BIN=mediamtx

# ── RTMP / HLS (when ENABLE_RTMP_SERVER=true) ───────────────────────────────
RTMP_PORT=1935
HLS_HTTP_PORT=8888
# Override FFmpeg RTMP target (empty = local MediaMTX or API default)
RTMP_FORWARD_URL=

# ── Low-latency HLS (MediaMTX) ──────────────────────────────────────────────
HLS_VARIANT=lowLatency
HLS_SEGMENT_DURATION=1s
HLS_PART_DURATION=200ms
HLS_SEGMENT_COUNT=8
HLS_SEGMENT_SEC=1
HLS_ENCODE_FPS=30
HLS_ALWAYS_REMUX=true

# ── API / ingest events ──────────────────────────────────────────────────────
API_FETCH_TIMEOUT_MS=15000
INGEST_EVENT_MAX_ATTEMPTS=3

# ── Capacity & abuse ─────────────────────────────────────────────────────────
MAX_CONCURRENT_WS_STREAMS=0
MAX_MESSAGE_SIZE_BYTES=4194304
WS_UPGRADE_RATE_PER_MINUTE_IP=40
HLS_PROXY_ORIGIN_TIMEOUT_MS=180000
MEDIAMTX_READ_TIMEOUT=60s
MEDIAMTX_WRITE_TIMEOUT=60s

# ── Multi-replica (optional) ─────────────────────────────────────────────────
# Same Redis URL as API recommended when running multiple ingest replicas
# REDIS_URL=redis://default:password@host:6379
LIVE_INGEST_LOCK_TTL_SEC=90
# LIVE_INGEST_LOCK_REFRESH_MS=
INSTANCE_ID=
# RAILWAY_REPLICA_ID=

# ── Cloudflare Stream (optional; avoids local transcode scale limits) ───────
CF_STREAM_MODE=false
# CF_ACCOUNT_ID=
# CF_STREAM_API_TOKEN=
